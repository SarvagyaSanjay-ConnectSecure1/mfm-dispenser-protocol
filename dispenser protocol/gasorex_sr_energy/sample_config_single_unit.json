{
  "# Configuration for Gasorex SR Energy Dispenser - Single Unit (Both Sides)": "",
  "# This configuration reads both Side A and Side B from a single GSR-CU-23 controller": "",
  "# Update slave address and identifiers as needed for your deployment": "",

  "ro_code": "GASOREX_SR_ENERGY_PUMP_001",
  "c_id": 2001,
  "c_make": "Gasorex_SR_Energy_GSR_CU_23",
  "post_interval": 30,
  "status_interval": 900,

  "# RS-485 Modbus RTU Configuration": "",
  "# Baud rate, data bits, parity, and stop bits per GSR-CU-23 specification": "",
  "mbus_RTU": {
    "slave": 1,
    "baud": 9600,
    "dataBits": 8,
    "parity": "E",
    "stopBits": 1
  },

  "# Register mapping (Modbus address ranges to read)": "",
  "# Registers 1-14:  Side A data (amount, quantity, totalizers, pressures, flowrate, error, e-stop)": "",
  "# Registers 16-30: Side B data (same structure as Side A)": "",
  "# Pricing registers 31-34 are read-only in this config (optional, can be added if needed)": "",
  "m": [
    1, 14,
    16, 15
  ],

  "# OTA (Firmware updates for ESP32)": "",
  "ota": {
    "ver": "2.1.6",
    "bin_url": "https://your-cloud/firmware/gasorex/2.1.6/app.bin",
    "checksum_url": "https://your-cloud/firmware/gasorex/2.1.6/checksums.json"
  }
}
